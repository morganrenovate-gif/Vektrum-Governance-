NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_webhook_signing_secret_here

NEXT_PUBLIC_APP_URL=https://vektrum-governance.vercel.app

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# Used for transactional notifications: payout failures, retry confirmations, etc.
# Obtain an API key at https://resend.com
RESEND_API_KEY=re_your_resend_api_key_here
# Verified sender address/domain in your Resend account
EMAIL_FROM=Vektrum <noreply@vektrum.io>
# Comma-separated list of operator email addresses that receive critical alerts
ADMIN_EMAIL=ops@vektrum.io

# ── Cron authentication ────────────────────────────────────────────────────────
# Vercel sets this automatically for cron invocations when configured in vercel.json.
# Set the same value here for local testing of /api/cron/* endpoints.
CRON_SECRET=your_cron_secret_here

# ── Perplexity AI (draw review, contract analysis, assistant) ─────────────────
# Used by: /api/ai/draw-review, /api/analyze-contract, /api/assistant
# Also required in Supabase Edge Functions: analyze-contract, generate-dispute-brief
#   (set separately via Supabase dashboard → Settings → Edge Functions → Secrets)
# Obtain at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-your_key_here

# ── DocuSign eSign ─────────────────────────────────────────────────────────────
# Required for contract PDF signing. See src/lib/engine/docusign.ts for setup.
#
# 1. Create an app at https://developers.docusign.com
# 2. Generate an RSA keypair in app settings; base64-encode the private key
# 3. Grant consent once: https://{DOCUSIGN_OAUTH_HOST}/oauth/auth?response_type=code
#    &scope=signature%20impersonation&client_id={DOCUSIGN_INTEGRATION_KEY}
#    &redirect_uri={APP_URL}/auth/docusign/callback
# 4. In DocuSign Admin → Connect → add webhook pointing to /api/webhooks/docusign
#    with the HMAC key matching DOCUSIGN_WEBHOOK_SECRET below.
#
DOCUSIGN_INTEGRATION_KEY=your_integration_key_here
DOCUSIGN_USER_ID=your_docusign_user_uuid_here
DOCUSIGN_ACCOUNT_ID=your_docusign_account_uuid_here
# RSA private key from DocuSign app settings, base64-encoded (single line)
DOCUSIGN_PRIVATE_KEY=base64_encoded_rsa_private_key
# Sandbox: account-d.docusign.com | Production: account.docusign.com
DOCUSIGN_OAUTH_HOST=account-d.docusign.com
# Sandbox: https://demo.docusign.net/restapi | Production: https://na3.docusign.net/restapi
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi
# HMAC secret registered in DocuSign Connect configuration
DOCUSIGN_WEBHOOK_SECRET=your_docusign_webhook_hmac_secret
