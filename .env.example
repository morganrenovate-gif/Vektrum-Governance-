# ── Authorization Token Signing (ed25519) ─────────────────────────────────────
# Required to activate cryptographic signing of authorization tokens (patent claim #1).
# Without this, tokens are issued with signature_alg='unsigned' — functional but
# not cryptographically verifiable by partners.
#
# Generate a keypair:  node scripts/generate-token-signing-key.mjs
# Store the private key here. Save the public key PEM for the partner verifier.
#
# Format: base64-encoded PKCS8 DER (single line — what the keygen script outputs).
# PEM format is also accepted (BEGIN PRIVATE KEY header auto-detected).
VEKTRUM_TOKEN_SIGNING_KEY_PRIVATE=

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_webhook_signing_secret_here

NEXT_PUBLIC_APP_URL=https://vektrum-governance.vercel.app

# ── Demo ───────────────────────────────────────────────────────────────────────
# Set to true to allow POST /api/demo/reset in production environments.
# Omit or leave false in production unless you are running a dedicated demo tenant.
DEMO_RESET_ENABLED=false

# ── Admin promotion ────────────────────────────────────────────────────────────
# POST /api/admin/promote is DISABLED by default.
# Admin creation is an owner-controlled operation. Do NOT set this to true in
# production unless you have a specific, time-limited need. Revert immediately after.
# See src/app/api/admin/promote/route.ts for full rationale.
ADMIN_PROMOTION_ENABLED=false

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# Used for transactional notifications: payout failures, retry confirmations, etc.
# Obtain an API key at https://resend.com
RESEND_API_KEY=re_your_resend_api_key_here
# Verified sender address/domain in your Resend account
EMAIL_FROM=Vektrum <noreply@vektrum.io>
# Comma-separated list of operator email addresses that receive critical alerts
ADMIN_EMAIL=ops@vektrum.io

# ── Cron authentication ────────────────────────────────────────────────────────
# Vercel sets this automatically for cron invocations when configured in vercel.json.
# Set the same value here for local testing of /api/cron/* endpoints.
CRON_SECRET=your_cron_secret_here

# ── AI Providers (draw review, contract analysis, assistant) ──────────────────
# Perplexity is the PRIMARY provider. Anthropic and OpenAI are automatic fallbacks
# tried in order when Perplexity is unavailable.
#
# Provider chain: Perplexity sonar-pro → Anthropic claude-sonnet-4-20250514 → OpenAI gpt-4o
# All three are optional individually, but at least one must be configured for
# draw review to work. Configure all three for maximum resilience.
#
# Perplexity — primary provider
# Obtain at: https://www.perplexity.ai/settings/api
# Also required in Supabase Edge Functions: analyze-contract, generate-dispute-brief
#   (set separately via Supabase dashboard → Settings → Edge Functions → Secrets)
PERPLEXITY_API_KEY=pplx-your_key_here

# Anthropic — first fallback provider
# Obtain at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# OpenAI — second fallback provider
# Obtain at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_key_here

# ── AI Provider Tuning ─────────────────────────────────────────────────────────
# Per-provider timeout before the chain moves to the next provider (milliseconds).
# Default: 10000 (10 seconds). Lower values make failover faster but may cause
# false failures on slow networks.
AI_PROVIDER_TIMEOUT_MS=10000

# TTL for admin AI-review overrides (hours). Overrides are emergency bypasses
# used when all AI providers are unavailable and a release is time-critical.
# Much shorter than the normal 48 h AI assessment TTL to limit blast radius.
# Default: 4 hours.
AI_ADMIN_OVERRIDE_TTL_HOURS=4

# ── DocuSign eSign ─────────────────────────────────────────────────────────────
# Required for contract PDF signing. See src/lib/engine/docusign.ts for setup.
#
# 1. Create an app at https://developers.docusign.com
# 2. Generate an RSA keypair in app settings; base64-encode the private key
# 3. Grant consent once: https://{DOCUSIGN_OAUTH_HOST}/oauth/auth?response_type=code
#    &scope=signature%20impersonation&client_id={DOCUSIGN_INTEGRATION_KEY}
#    &redirect_uri={APP_URL}/auth/docusign/callback
# 4. In DocuSign Admin → Connect → add webhook pointing to /api/webhooks/docusign
#    with the HMAC key matching DOCUSIGN_WEBHOOK_SECRET below.
#
DOCUSIGN_INTEGRATION_KEY=your_integration_key_here
DOCUSIGN_USER_ID=your_docusign_user_uuid_here
DOCUSIGN_ACCOUNT_ID=your_docusign_account_uuid_here
# RSA private key from DocuSign app settings, base64-encoded (single line)
DOCUSIGN_PRIVATE_KEY=base64_encoded_rsa_private_key
# Sandbox: account-d.docusign.com | Production: account.docusign.com
DOCUSIGN_OAUTH_HOST=account-d.docusign.com
# Sandbox: https://demo.docusign.net/restapi | Production: https://na3.docusign.net/restapi
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi
# HMAC secret registered in DocuSign Connect configuration.
# REQUIRED in all deployed environments: production, staging, and Vercel preview branches.
# Missing this secret in any deployed context causes the webhook to return 500
# and process nothing (fail-closed). There is no bypass for deployed builds.
DOCUSIGN_WEBHOOK_SECRET=your_docusign_webhook_hmac_secret

# ── DocuSign webhook HMAC bypass (LOCAL DEVELOPMENT ONLY) ─────────────────────
# Set to true ONLY on a local dev machine when you do not have a real DocuSign
# HMAC secret and need to test webhook handling locally (e.g. via ngrok + sandbox).
#
# This bypass requires BOTH conditions simultaneously:
#   1. NODE_ENV=development   (Next.js sets this automatically for `next dev`)
#   2. DOCUSIGN_WEBHOOK_DEV_BYPASS=true
#
# Next.js sets NODE_ENV='production' for ALL Vercel deployments (including
# preview branches), so this flag has no effect in any deployed environment.
#
# NEVER set this to true in staging, preview, or production env files.
DOCUSIGN_WEBHOOK_DEV_BYPASS=false
