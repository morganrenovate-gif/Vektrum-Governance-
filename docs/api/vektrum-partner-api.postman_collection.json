{
  "info": {
    "name": "Vektrum Partner API",
    "description": "Partner API for confirming and failing external release executions on Vektrum-authorized construction disbursements.\n\nBase URL: {{base_url}}\n\nAuthentication: Bearer token \u2014 set `partner_api_key` in the environment.\n\nAll requests are scoped to the authenticated partner's deals only. Every call is written to the Vektrum audit log.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": {
      "major": 1,
      "minor": 0,
      "patch": 0
    }
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{partner_api_key}}",
        "type": "string"
      }
    ]
  },
  "variable": [],
  "item": [
    {
      "name": "Releases",
      "description": "Endpoints for viewing, confirming, and failing release executions.",
      "item": [
        {
          "name": "Get Release",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/partner/releases/{{release_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "partner",
                "releases",
                "{{release_id}}"
              ]
            },
            "description": "Retrieve the current status of a release.\n\nReturns the release ID, deal and milestone context, amount breakdown, execution status, execution rail, and authorization timestamp.\n\nOnly returns releases that belong to the authenticated partner's deals."
          },
          "response": [
            {
              "name": "200 OK \u2014 Pending release",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"release\": {\n    \"id\": \"a1b2c3d4-e5f6-7890-abcd-ef1234567890\",\n    \"deal_id\": \"d1e2f3a4-b5c6-7890-abcd-ef1234567891\",\n    \"deal_title\": \"Riverside Phase 2\",\n    \"milestone_id\": \"m1n2o3p4-q5r6-7890-abcd-ef1234567892\",\n    \"milestone_title\": \"Foundation Complete\",\n    \"amount\": 125000,\n    \"fee_amount\": 1250,\n    \"retainage_amount\": 6250,\n    \"net_to_contractor\": 118750,\n    \"execution_status\": \"pending\",\n    \"execution_rail\": \"external_manual\",\n    \"execution_notes\": null,\n    \"authorized_at\": \"2025-04-15T14:32:00.000Z\"\n  }\n}",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{base_url}}/api/partner/releases/{{release_id}}",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "api",
                    "partner",
                    "releases",
                    "{{release_id}}"
                  ]
                }
              }
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"error\": \"Unauthorized\"\n}",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{base_url}}/api/partner/releases/{{release_id}}",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "api",
                    "partner",
                    "releases",
                    "{{release_id}}"
                  ]
                }
              }
            },
            {
              "name": "403 Forbidden",
              "status": "Forbidden",
              "code": 403,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"error\": \"Forbidden\"\n}",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{base_url}}/api/partner/releases/{{release_id}}",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "api",
                    "partner",
                    "releases",
                    "{{release_id}}"
                  ]
                }
              }
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"error\": \"Release not found\"\n}",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{base_url}}/api/partner/releases/{{release_id}}",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "api",
                    "partner",
                    "releases",
                    "{{release_id}}"
                  ]
                }
              }
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has release object\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('release');",
                  "    pm.expect(body.release).to.have.property('id');",
                  "    pm.expect(body.release).to.have.property('execution_status');",
                  "    pm.expect(body.release).to.have.property('execution_rail');",
                  "    pm.expect(body.release).to.have.property('authorized_at');",
                  "});",
                  "",
                  "pm.test(\"execution_status is a known value\", function () {",
                  "    const body = pm.response.json();",
                  "    const validStatuses = ['pending', 'confirmed', 'failed'];",
                  "    pm.expect(validStatuses).to.include(body.release.execution_status);",
                  "});",
                  "",
                  "pm.test(\"execution_rail is a known value\", function () {",
                  "    const body = pm.response.json();",
                  "    const validRails = ['external_manual', 'stripe_connect'];",
                  "    pm.expect(validRails).to.include(body.release.execution_rail);",
                  "});",
                  "",
                  "// Save release_id for use in subsequent requests",
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.environment.set('release_id', body.release.id);",
                  "    pm.environment.set('release_status', body.release.execution_status);",
                  "    pm.environment.set('release_rail', body.release.execution_rail);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Confirm Release Execution",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payment_method\": \"wire\",\n  \"payment_reference\": \"FED-20250415-00123\",\n  \"executed_at\": \"2025-04-15T16:00:00.000Z\",\n  \"notes\": \"Confirmed by treasury at 4pm Eastern\",\n  \"proof_document_id\": null\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/partner/releases/{{release_id}}/confirm",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "partner",
                "releases",
                "{{release_id}}",
                "confirm"
              ]
            },
            "description": "Confirm that an external payment was executed. Records the payment method, reference, and proof in the Vektrum audit trail.\n\n**Only available for:**\n- `execution_rail` = `external_manual`\n- `execution_status` = `pending`\n\n**Idempotent:** Calling this on an already-confirmed release returns 200 with `alreadyConfirmed: true`.\n\n**`payment_method`** must be one of: `wire`, `ach`, `check`, `other`\n\n**`executed_at`** (optional) \u2014 ISO-8601 timestamp. Defaults to current time. Cannot be a future timestamp. Cannot be more than 90 days in the past.\n\n**`proof_document_id`** (optional) \u2014 UUID of a document already associated with the release's milestone."
          },
          "response": [
            {
              "name": "200 OK \u2014 Confirmed",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"success\": true,\n  \"releaseId\": \"a1b2c3d4-e5f6-7890-abcd-ef1234567890\",\n  \"execution_status\": \"confirmed\",\n  \"execution_rail\": \"external_manual\",\n  \"confirmed_by\": \"partner\",\n  \"partner_id\": \"p1a2b3c4-d5e6-7890-abcd-ef1234567893\",\n  \"external\": {\n    \"payment_method\": \"wire\",\n    \"payment_reference\": \"FED-20250415-00123\",\n    \"executed_at\": \"2025-04-15T16:00:00.000Z\",\n    \"notes\": null,\n    \"proof_document_id\": null\n  },\n  \"billing\": {\n    \"gross_amount\": 125000,\n    \"fee_amount\": 1250,\n    \"retainage_amount\": 6250,\n    \"net_to_contractor\": 118750,\n    \"billing_rate_bps\": 100,\n    \"total_debit\": 126250,\n    \"committed\": true\n  },\n  \"ledger_updated\": true,\n  \"warnings\": []\n}",
              "originalRequest": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"payment_method\": \"wire\",\n  \"payment_reference\": \"FED-20250415-00123\",\n  \"executed_at\": \"2025-04-15T16:00:00.000Z\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/partner/releases/{{release_id}}/confirm",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "api",
                    "partner",
                    "releases",
                    "{{release_id}}",
                    "confirm"
                  ]
                }
              }
            },
            {
              "name": "200 OK \u2014 Already Confirmed (idempotent)",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"success\": true,\n  \"releaseId\": \"a1b2c3d4-e5f6-7890-abcd-ef1234567890\",\n  \"alreadyConfirmed\": true,\n  \"execution_status\": \"confirmed\",\n  \"external_payment_reference\": \"FED-20250415-00123\",\n  \"external_executed_at\": \"2025-04-15T16:00:00.000Z\",\n  \"note\": \"This release has already been confirmed. No further action was taken.\"\n}",
              "originalRequest": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"payment_method\": \"wire\",\n  \"payment_reference\": \"FED-20250415-00123\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/partner/releases/{{release_id}}/confirm",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "api",
                    "partner",
                    "releases",
                    "{{release_id}}",
                    "confirm"
                  ]
                }
              }
            },
            {
              "name": "400 Bad Request",
              "status": "Bad Request",
              "code": 400,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"error\": \"Invalid request body\",\n  \"details\": \"payment_method must be one of: wire, ach, check, other\"\n}",
              "originalRequest": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"payment_method\": \"bitcoin\",\n  \"payment_reference\": \"ref123\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/partner/releases/{{release_id}}/confirm",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "api",
                    "partner",
                    "releases",
                    "{{release_id}}",
                    "confirm"
                  ]
                }
              }
            },
            {
              "name": "409 Conflict",
              "status": "Conflict",
              "code": 409,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"error\": \"Concurrent state change in progress. Retry after a short delay.\"\n}",
              "originalRequest": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"payment_method\": \"wire\",\n  \"payment_reference\": \"ref123\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/partner/releases/{{release_id}}/confirm",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "api",
                    "partner",
                    "releases",
                    "{{release_id}}",
                    "confirm"
                  ]
                }
              }
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Success is true\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.success).to.be.true;",
                  "});",
                  "",
                  "pm.test(\"execution_status is confirmed\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.execution_status).to.equal('confirmed');",
                  "});",
                  "",
                  "pm.test(\"Response includes alreadyConfirmed field\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('alreadyConfirmed');",
                  "    pm.expect(body.alreadyConfirmed).to.be.a('boolean');",
                  "});",
                  "",
                  "pm.test(\"Response includes billing breakdown\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('billing');",
                  "    pm.expect(body.billing).to.have.property('amount');",
                  "    pm.expect(body.billing).to.have.property('net_to_contractor');",
                  "});",
                  "",
                  "pm.test(\"Response includes warnings array\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('warnings');",
                  "    pm.expect(body.warnings).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Fail Release Execution",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Wire rejected by receiving bank \u2014 account number mismatch.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/partner/releases/{{release_id}}/fail",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "partner",
                "releases",
                "{{release_id}}",
                "fail"
              ]
            },
            "description": "Report that an external payment execution failed. Cancels the balance reservation and preserves audit visibility.\n\n**Only available for:**\n- `execution_rail` = `external_manual`\n- `execution_status` = `pending`\n\n**Important:** Failing a release does NOT revert the milestone status. The milestone remains `released`. Contact Vektrum if the milestone needs to be reverted.\n\n**`reason`** is required. Minimum 10 characters, maximum 2000 characters."
          },
          "response": [
            {
              "name": "200 OK \u2014 Failed",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"success\": true,\n  \"releaseId\": \"a1b2c3d4-e5f6-7890-abcd-ef1234567890\",\n  \"execution_status\": \"failed\",\n  \"execution_rail\": \"external_manual\",\n  \"reason\": \"Wire rejected by receiving bank \\u2014 account number mismatch.\",\n  \"reservation_cancelled\": true,\n  \"milestone_status_unchanged\": true,\n  \"note\": \"Release marked failed and funded-balance reservation freed. Milestone remains in released state \\u2014 contact Vektrum admin to revert if needed.\"\n}",
              "originalRequest": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"reason\": \"Wire rejected by receiving bank \u2014 account number mismatch.\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/partner/releases/{{release_id}}/fail",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "api",
                    "partner",
                    "releases",
                    "{{release_id}}",
                    "fail"
                  ]
                }
              }
            },
            {
              "name": "400 Bad Request \u2014 reason too short",
              "status": "Bad Request",
              "code": 400,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"error\": \"Invalid request body\",\n  \"details\": \"reason must be at least 10 characters\"\n}",
              "originalRequest": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"reason\": \"Rejected\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/partner/releases/{{release_id}}/fail",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "api",
                    "partner",
                    "releases",
                    "{{release_id}}",
                    "fail"
                  ]
                }
              }
            },
            {
              "name": "409 Conflict",
              "status": "Conflict",
              "code": 409,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"error\": \"Concurrent state change in progress. Retry after a short delay.\"\n}",
              "originalRequest": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"reason\": \"Wire rejected by receiving bank.\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/partner/releases/{{release_id}}/fail",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "api",
                    "partner",
                    "releases",
                    "{{release_id}}",
                    "fail"
                  ]
                }
              }
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Success is true\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.success).to.be.true;",
                  "});",
                  "",
                  "pm.test(\"execution_status is failed\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.execution_status).to.equal('failed');",
                  "});",
                  "",
                  "pm.test(\"reservation_cancelled is true\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.reservation_cancelled).to.be.true;",
                  "});",
                  "",
                  "pm.test(\"milestone_status_unchanged is true\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.milestone_status_unchanged).to.be.true;",
                  "});",
                  "",
                  "pm.test(\"reason is echoed in response\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('reason');",
                  "    pm.expect(body.reason).to.be.a('string');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}